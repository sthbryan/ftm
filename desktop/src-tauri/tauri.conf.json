{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foundry Tunnel Manager",
  "version": "0.3.0",
  "identifier": "com.foundrytunnel",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ../web-svelte && bun install && bun run build",
    "frontendDist": "../web-svelte/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
    "bundle": {
      "active": true,
      "targets": "all",
      "resources": ["go-backend"],
      "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
    }
}
