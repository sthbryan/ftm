{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foundry Tunnel Manager",
  "version": "0.4.1",
  "identifier": "com.foundry-tunnel.manager",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../../web-svelte/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Foundry Tunnel Manager",
        "url": "about:blank",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
